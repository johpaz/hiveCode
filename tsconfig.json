{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "paths": {
      "@johpaz/hivecode": [
        "./packages/core/src/index.ts"
      ],
      "@johpaz/hivecode/agent/*": [
        "./packages/core/src/agent/*"
      ],
      "@johpaz/hivecode/channels/*": [
        "./packages/core/src/channels/*"
      ],
      "@johpaz/hivecode/storage/*": [
        "./packages/core/src/storage/*"
      ],
      "@johpaz/hivecode/tools/*": [
        "./packages/core/src/tools/*"
      ],
      "@johpaz/hivecode/config/*": [
        "./packages/core/src/config/*"
      ],
      "@johpaz/hivecode/utils/*": [
        "./packages/core/src/utils/*"
      ],
      "@johpaz/hivecode/gateway/*": [
        "./packages/core/src/gateway/*"
      ],
      "@johpaz/hivecode/mcp/*": [
        "./packages/mcp/src/*"
      ],
      "@johpaz/hivecode/skills/*": [
        "./packages/skills/src/*"
      ],
      "@johpaz/hivecode-core": [
        "./packages/core/src/index.ts"
      ],
      "@johpaz/hivecode-core/*": [
        "./packages/core/src/*"
      ],
      "@johpaz/hivecode-mcp": [
        "./packages/mcp/src/index.ts"
      ],
      "@johpaz/hivecode-mcp/*": [
        "./packages/mcp/src/*"
      ],
      "@johpaz/hivecode-skills": [
        "./packages/skills/src/index.ts"
      ],
      "@johpaz/hivecode-skills/*": [
        "./packages/skills/src/*"
      ],
      "@johpaz/hivecode-cli": [
        "./packages/cli/src/index.ts"
      ],
      "@johpaz/hivecode-code": [
        "./packages/code/src/index.ts"
      ],
      "@johpaz/hivecode-code/*": [
        "./packages/code/src/*"
      ]
    }
  },
  "include": [
    "packages/*/src/**/*",
    "tests/**/*",
    "scripts/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
